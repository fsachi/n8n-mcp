#Rename this file to .env

#n8n
N8N_HOST=http://localhost:5678
N8N_PASSWORD=change_your_password #Change with your password
N8N_USER_NAME=joedoe@example.com #Change with your user name
N8N_USER_EMAIL=joedoe@example.com #Change with your user email

#n8n-mcp
AUTH_TOKEN=Authorization_Token_paste_here #Paste your Authorization Token here, created with n8n-mcp initial setup
MCP_MODE=http
PORT=3000
# Optional: Enable n8n management tools
# N8N_API_URL=https://your-n8n-instance.com
# N8N_API_KEY=your-api-key-here
# Security Configuration (v2.16.3+)
# Rate limiting (default: 20 attempts per 15 minutes)
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX=20
# SSRF protection mode (default: strict)
# Use 'moderate' for local n8n, 'strict' for production
WEBHOOK_SECURITY_MODE=strict